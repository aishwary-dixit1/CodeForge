# PostgreSQL connection string
# Example: postgresql://postgres:postgres@localhost:5432/codeforge
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codeforge

# RabbitMQ connection string
# Example: amqp://localhost
# docker run -d --hostname rabbitmq --name rabbitmq -p 5672:5672 -p 15672:15672 rabbitmq:3-management
RABBITMQ_URL=amqp://localhost

# Queue name used by API and workers
EXECUTION_QUEUE=execution.queue

# Sweep batch size for pending requeue job
REQUEUE_BATCH_SIZE=100

# Phase 2 execution engine limits
EXEC_MEMORY_LIMIT=256m
EXEC_CPU_LIMIT=0.5
EXEC_PIDS_LIMIT=64
EXEC_TMPFS=/tmp:size=32m,noexec,nodev,nosuid

# Optional language runner image overrides
IMAGE_PYTHON3=codeforge/runner-python3:latest
IMAGE_NODEJS20=codeforge/runner-nodejs20:latest
IMAGE_JAVA17=codeforge/runner-java17:latest
IMAGE_CPP20=codeforge/runner-cpp20:latest

# Phase 2 smoke test inputs
PHASE2_LANG=python3
PHASE2_CODE=print('hello')
PHASE2_STDIN=
PHASE2_EXPECTED=hello
PHASE2_TIMEOUT=10
